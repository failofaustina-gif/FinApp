function buildGraficoResumen(cats_data, total){
  var tipo=getGraficoTipo();
  var html='<div class="card" style="margin-bottom:12px">';
  html+='<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">';
  html+='<div class="ct" style="margin-bottom:0">Distribucion del gasto mensual</div>';
  html+='<div style="display:flex;gap:6px">';
  html+='<button onclick="setGraficoTipo(\'dona\')" style="padding:4px 10px;border-radius:6px;border:1px solid '+(tipo==='dona'?'var(--accent2)':'var(--border)')+';background:'+(tipo==='dona'?'var(--accentDim)':'var(--card)')+';font-size:.72rem;font-weight:'+(tipo==='dona'?'600':'400')+';color:'+(tipo==='dona'?'var(--accent)':'var(--ink3)')+';cursor:pointer;font-family:DM Sans,sans-serif">🍩 Dona</button>';
  html+='<button onclick="setGraficoTipo(\'barras\')" style="padding:4px 10px;border-radius:6px;border:1px solid '+(tipo==='barras'?'var(--accent2)':'var(--border)')+';background:'+(tipo==='barras'?'var(--accentDim)':'var(--card)')+';font-size:.72rem;font-weight:'+(tipo==='barras'?'600':'400')+';color:'+(tipo==='barras'?'var(--accent)':'var(--ink3)')+';cursor:pointer;font-family:DM Sans,sans-serif">📊 Barras</button>';
  html+='</div></div>';

  if(cats_data.length===0){html+='<div class="empty">Sin datos.</div></div>';return html;}

  if(tipo==='dona'){
    // Dona SVG
    var paths='',ang=-Math.PI/2;
    cats_data.forEach(function(c){
      var pct=c.val/total,end=ang+pct*Math.PI*2;
      var x1=80+65*Math.cos(ang),y1=80+65*Math.sin(ang);
      var x2=80+65*Math.cos(end),y2=80+65*Math.sin(end);
      var lg=pct>.5?1:0;
      paths+='<path d="M80,80 L'+x1.toFixed(1)+','+y1.toFixed(1)+' A65,65 0 '+lg+',1 '+x2.toFixed(1)+','+y2.toFixed(1)+' Z" fill="'+c.color+'" opacity=".88"/>';
      ang=end;
    });
    paths+='<circle cx="80" cy="80" r="30" fill="var(--bg)"/>';
    paths+='<text x="80" y="77" text-anchor="middle" font-size="9" font-family="DM Sans" fill="var(--ink3)">Total</text>';
    paths+='<text x="80" y="90" text-anchor="middle" font-size="8.5" font-weight="700" font-family="DM Sans" fill="var(--ink)">'+fA(total).replace('$','')+'</text>';
    html+='<div style="display:flex;align-items:center;gap:20px;flex-wrap:wrap">';
    html+='<svg viewBox="0 0 160 160" width="160" height="160">'+paths+'</svg>';
    html+='<div style="flex:1;min-width:160px">';
    cats_data.forEach(function(c){
      html+='<div style="display:flex;align-items:center;gap:7px;margin-bottom:7px;font-size:.8rem">';
      html+='<div style="width:9px;height:9px;border-radius:2px;background:'+c.color+';flex-shrink:0"></div>';
      html+='<span style="flex:1;color:var(--ink2)">'+c.label+'</span>';
      html+='<span style="font-weight:700">'+Math.round(c.val/total*100)+'%</span>';
      html+='<span style="color:var(--ink3);font-size:.72rem">'+fA(c.val)+'</span>';
      html+='</div>';
    });
    html+='</div></div>';
  } else {
    // Barras horizontales
    var max=Math.max.apply(null,cats_data.map(function(c){return c.val;}));
    cats_data.forEach(function(c){
      var pct=max>0?(c.val/max)*100:0;
      html+='<div style="margin-bottom:10px">';
      html+='<div style="display:flex;justify-content:space-between;font-size:.8rem;margin-bottom:3px">';
      html+='<span style="color:var(--ink2)">'+c.label+'</span>';
      html+='<span style="font-weight:700">'+fA(c.val)+' <span style="color:var(--ink3);font-weight:400">('+Math.round(c.val/total*100)+'%)</span></span>';
      html+='</div>';
      html+='<div style="height:8px;background:var(--border);border-radius:100px;overflow:hidden">';
      html+='<div style="height:100%;width:'+pct+'%;background:'+c.color+';border-radius:100px;transition:width .4s"></div>';
      html+='</div></div>';
    });
  }
  html+='</div>';
  return html;
}

