<script>



var _varFiltro=null;

function selVarFiltro(btn){
  _varFiltro=btn.getAttribute('data-cat');
  rFinVars();
}

function toggleGvDetail(row){
  var id=row.getAttribute('data-gid');
  var det=document.getElementById('gvd-'+id);
  var exp=document.getElementById('gve-'+id);
  if(!det)return;
  var open=det.classList.contains('open');
  det.classList.toggle('open',!open);
  if(exp)exp.textContent=open?'▼':'▲';
}

function rFinVars(el){
  if(!el)el=document.getElementById('fin-c');
  if(!el)return;
  var tc=S.macro.tipoCambio||1200;
  var fmt=function(v){return S.moneda==='USD'?'USD '+(v/tc).toFixed(2):fA(v);};
  var totV=S.vars.reduce(function(s,g){return s+toN(g.monto);},0);
  var porCat={};
  S.vars.forEach(function(g){var c=g.categoria||'Otros';porCat[c]=(porCat[c]||0)+toN(g.monto);});
  var wrap=document.createElement('div');
  var hdr=document.createElement('div');hdr.className='fsh';hdr.style.marginBottom='10px';
  hdr.innerHTML='<div><span class="fst">Variables del mes</span><span style="font-size:.82rem;color:var(--ink3);margin-left:8px">'+fmt(totV)+'</span></div>';
  var btnAdd=document.createElement('button');btnAdd.className='ab';btnAdd.textContent='+ Agregar';
  btnAdd.onclick=function(){addVar();rFinVars();};hdr.appendChild(btnAdd);wrap.appendChild(hdr);
  var fd=document.createElement('div');fd.className='cat-filter';
  var ba=document.createElement('button');ba.className='cat-filter-btn';ba.textContent='Todos';
  if(!_varFiltro){ba.style.background='var(--accent)';ba.style.color='#fff';ba.style.borderColor='var(--accent)';}
  ba.onclick=function(){_varFiltro=null;rFinVars();};fd.appendChild(ba);
  Object.keys(porCat).forEach(function(cat){
    var color=getColorCategoria(cat);var isOn=_varFiltro===cat;
    var b=document.createElement('button');b.className='cat-filter-btn';b.setAttribute('data-cat',cat);
    b.style.cssText='border-color:'+color+'40;background:'+(isOn?color:'transparent')+';color:'+(isOn?'#fff':color);
    b.textContent=cat+' '+fmt(porCat[cat]);b.onclick=function(){selVarFiltro(this);};fd.appendChild(b);
  });wrap.appendChild(fd);
  var lista=_varFiltro?S.vars.filter(function(g){return(g.categoria||'Otros')===_varFiltro;}):S.vars;
  if(!lista.length){
    var empty=document.createElement('div');empty.className='empty';empty.textContent='Sin gastos en esta categoria.';wrap.appendChild(empty);
  } else {
    var ql=document.createElement('div');ql.className='ql';
    lista.forEach(function(g){
      var color=getColorCategoria(g.categoria||'Otros');
      var row=document.createElement('div');row.className='gv-row';row.setAttribute('data-gid',g.id);
      row.onclick=function(){toggleGvDetail(this);};
      var dot=document.createElement('div');dot.className='gv-cat-dot';dot.style.background=color;
      var conc=document.createElement('div');conc.className='gv-concepto';conc.textContent=g.nombre||'Sin nombre';
      var fech=document.createElement('div');fech.className='gv-fecha';fech.textContent=g.fecha||'';
      var mto=document.createElement('div');mto.className='gv-monto';mto.textContent=fmt(toN(g.monto));
      var exp=document.createElement('div');exp.className='gv-expand';exp.id='gve-'+g.id;exp.textContent='▼';
      row.appendChild(dot);row.appendChild(conc);row.appendChild(fech);row.appendChild(mto);row.appendChild(exp);
      ql.appendChild(row);
      var det=document.createElement('div');det.className='gv-detail';det.id='gvd-'+g.id;
      var cats=getCategorias().map(function(c){return '<option value="'+c.nombre+'"'+(c.nombre===(g.categoria||'Otros')?' selected':'')+'>'+c.nombre+'</option>';}).join('');
      det.innerHTML=
        '<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px">'+
          '<div class="fld"><label>Concepto</label><input class="di-n" type="text" value="" placeholder="Ej: Supermercado"/></div>'+
          '<div class="fld"><label>Monto ($)</label><div class="fp"><input class="di-m" type="number" value="" placeholder="0"/></div></div>'+
        '</div>'+
        '<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px">'+
          '<div class="fld"><label>Fecha</label><input class="di-f" type="text" value="" placeholder="2026-04-10"/></div>'+
          '<div class="fld"><label>Categoria</label><select class="di-c">'+cats+'</select></div>'+
        '</div><button class="db di-d">Eliminar</button>';
      det.querySelector('.di-n').value=g.nombre||'';
      det.querySelector('.di-m').value=g.monto||'';
      det.querySelector('.di-f').value=g.fecha||'';
      (function(gid){
        det.querySelector('.di-n').onchange=function(){updVar(gid,'nombre',this.value);};
        det.querySelector('.di-m').onchange=function(){updVar(gid,'monto',this.value);rFinVars();};
        det.querySelector('.di-f').onchange=function(){updVar(gid,'fecha',this.value);};
        det.querySelector('.di-c').onchange=function(){updVar(gid,'categoria',this.value);rFinVars();};
        det.querySelector('.di-d').onclick=function(){delVar(gid);rFinVars();};
      })(g.id);
      ql.appendChild(det);
    });
    wrap.appendChild(ql);
  }
  el.innerHTML='';el.appendChild(wrap);
}

window.onerror=function(m,s,l,c,e){document.body.insertAdjacentHTML("afterbegin","<div style=\"position:fixed;top:0;left:0;right:0;background:red;color:white;padding:10px;z-index:9999;font-size:12px\">JS ERROR: "+m+" (linea "+l+")</div>");return false;};
const S={
  usuario:JSON.parse(localStorage.getItem('fa_usuario')||'null'),
  moneda:localStorage.getItem('fa_moneda')||'USD',
  macro:JSON.parse(localStorage.getItem('fa_macro')||'{"inflMensual":3,"tipoCambio":1200,"devalMensual":2}'),
  favs:JSON.parse(localStorage.getItem('fa_favs')||'[]'),
  quotes:{},
  fijos:JSON.parse(localStorage.getItem('fa_fijos')||'[]'),
  vars:JSON.parse(localStorage.getItem('fa_vars')||'[]'),
  anuales:JSON.parse(localStorage.getItem('fa_anuales')||'[]'),
  tarjetas:JSON.parse(localStorage.getItem('fa_tarjetas')||'[]'),
  inversiones:JSON.parse(localStorage.getItem('fa_inversiones')||'[]'),
