.insmv{font-size:.72rem;font-weight:600}
.pr{display:flex;gap:8px;align-items:flex-start;margin-bottom:6px}
.pd{width:5px;height:5px;border-radius:50%;flex-shrink:0;margin-top:5px}
.pt2{font-size:.78rem;color:var(--ink2);line-height:1.5}
.gr{padding:10px 13px;border-bottom:1px solid var(--bg2)}
.gr:last-child{border-bottom:none}
.gt{font-size:.83rem;font-weight:700;margin-bottom:2px}
.gd{font-size:.76rem;color:var(--ink2);line-height:1.5}
.bdg{display:inline-block;border-radius:5px;padding:2px 7px;font-size:.66rem;font-weight:700}
