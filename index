// ── FLUJO DE CAJA ──────────────────────────────────────────────────────────
function rEmpFlujo(el){
  var ingresos=loadEmp('ingresos'),egresos=loadEmp('egresos');
  var totI=ingresos.reduce(function(s,i){return s+toN(i.monto);},0);
  var totE=egresos.reduce(function(s,e){return s+toN(e.monto);},0);
  var fn=totI-totE;

  // Alertas
  var alertas=[];
  if(totE>totI&&totI>0) alertas.push({msg:'Los egresos superan los ingresos este mes.',color:'var(--down)'});
  if(totI>0&&totE/totI>0.8) alertas.push({msg:'Los egresos representan mas del 80% de los ingresos. Margen muy ajustado.',color:'var(--warn)'});
  // Alertas por categoria
  var catEgr={};
  egresos.forEach(function(e){var c=e.categoria||'Otros';catEgr[c]=(catEgr[c]||0)+toN(e.monto);});
  var catIng={};
  ingresos.forEach(function(i){var c=i.categoria||'Otros';catIng[c]=(catIng[c]||0)+toN(i.monto);});
  if((catEgr['Sueldos']||0)>totI*0.6&&totI>0) alertas.push({msg:'Los sueldos superan el 60% de tus ingresos.',color:'var(--warn)'});
  if((catEgr['Impuestos']||0)>totI*0.3&&totI>0) alertas.push({msg:'Los impuestos superan el 30% de tus ingresos.',color:'var(--warn)'});

  var html='';
  // KPIs
  html+='<div class="card" style="margin-bottom:12px;border-color:'+(fn>=0?'var(--accent)':'var(--down)')+'40">';
  html+='<div class="ct">Flujo neto del mes</div>';
  html+='<div style="font-family:Fraunces,serif;font-size:2rem;font-weight:700;color:'+(fn>=0?'var(--up)':'var(--down)')+'">'+(fn>=0?'+':'')+fA(fn)+'</div>';
  html+='<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:10px">';
  html+='<div style="background:var(--upBg);border-radius:8px;padding:10px"><div style="font-size:.62rem;color:var(--up);font-weight:700;margin-bottom:2px">INGRESOS</div><div style="font-size:1.05rem;font-weight:700;color:var(--up)">+'+fA(totI)+'</div></div>';
  html+='<div style="background:var(--downBg);border-radius:8px;padding:10px"><div style="font-size:.62rem;color:var(--down);font-weight:700;margin-bottom:2px">EGRESOS</div><div style="font-size:1.05rem;font-weight:700;color:var(--down)">-'+fA(totE)+'</div></div>';
  html+='</div></div>';
  // Alertas
  alertas.forEach(function(a){
    html+='<div style="background:'+a.color+'15;border:1px solid '+a.color+'40;border-radius:10px;padding:11px 14px;margin-bottom:8px;font-size:.82rem;font-weight:600;color:'+a.color+'">⚠ '+a.msg+'</div>';
  });
  // Ingresos por categoría
  html+='<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px"><span class="fst">Ingresos</span><button class="ab" id="btn-add-ing" data-lista="ingresos">+ Agregar</button></div>';
  html+='<p style="font-size:.73rem;color:var(--ink3);margin-bottom:10px">Ventas, servicios, cobros del mes.</p>';
  if(ingresos.length){
    html+=ingresos.map(function(i){return empCard(i,'ingresos',CAT_ING,true);}).join('');
  } else {
    html+='<div class="empty">Sin ingresos. Toca Agregar.</div>';
  }
  html+='<div style="display:flex;align-items:center;justify-content:space-between;margin:16px 0 6px"><span class="fst">Egresos</span><button class="ab" id="btn-add-egr" data-lista="egresos">+ Agregar</button></div>';
  html+='<p style="font-size:.73rem;color:var(--ink3);margin-bottom:10px">Sueldos, proveedores, impuestos, cuotas.</p>';
