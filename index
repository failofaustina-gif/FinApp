  else if(/macro/i.test(text)) result.tarjeta.banco='Macro';
  if(/visa signature/i.test(text)) result.tarjeta.nombre='Visa Signature '+(result.tarjeta.banco||'');
  else if(/visa platinum/i.test(text)) result.tarjeta.nombre='Visa Platinum '+(result.tarjeta.banco||'');
  else if(/mastercard/i.test(text)) result.tarjeta.nombre='Mastercard '+(result.tarjeta.banco||'');
  else if(/amex|american express/i.test(text)) result.tarjeta.nombre='AMEX '+(result.tarjeta.banco||'');
  else result.tarjeta.nombre=(result.tarjeta.banco||'Tarjeta')+' Credito';
  // Saldo
  var mS=text.match(/SALDO ACTUAL[\s\$]+([\d.]+,\d{2})/i);
  if(mS) result.tarjeta.saldo=parseMonto(mS[1]);
  // Cierre y vencimiento (formato DD-Mmm-YY)
  var mC=text.match(/CIERRE ACTUAL\s+(\d{1,2})-(\w+)-(\d{2,4})/i);
  if(mC) result.tarjeta.cierre=parseInt(mC[1]);
  var mV=text.match(/VENCIMIENTO ACTUAL\s+(\d{1,2})-(\w+)-(\d{2,4})/i);
  if(mV) result.tarjeta.vencimiento=parseInt(mV[1]);

  // PDF.js puede juntar tokens con espacio en vez de \n
  // Forzar \n antes de cada fecha DD-Mmm-YY
  text=text.replace(/(\d{2}-[A-Za-z]{3}-\d{2,4})\s/g,'\n$1 ');
  var MESES={ene:'01',feb:'02',mar:'03',abr:'04',may:'05',jun:'06',jul:'07',ago:'08',sep:'09',oct:'10',nov:'11',dic:'12'};
  var SKIP=['SU PAGO','SALDO ANTERIOR','SALDO ACTUAL','TOTAL CONSUMOS','INTERESES','DB IVA','IIBB','IVA RG','DB.RG','CR.RG','PAGO MINIMO','FECHA DESCRIPCION'];
  var lines=text.split('\n');

  lines.forEach(function(line){
    line=line.trim();
    var mF=line.match(/^(\d{1,2})-([A-Za-z]{3})-(\d{2,4})\s+/);
    if(!mF) return;
    var skip=false;
    SKIP.forEach(function(k){if(line.toUpperCase().indexOf(k)>=0) skip=true;});
    if(skip) return;
    var dia=mF[1].length===1?'0'+mF[1]:mF[1];
    var mes=MESES[(mF[2]||'').toLowerCase().slice(0,3)]||'01';
    var anio=mF[3].length===2?'20'+mF[3]:mF[3];
    var fecha=anio+'-'+mes+'-'+dia;
    var resto=line.slice(mF[0].length).trim();
    // Cuotas C.NN/NN
    var cuotaActual=1,cuotaTotal=1;
    var mQ=resto.match(/C\.(\d{2})\/(\d{2})/i);
    if(mQ){cuotaActual=parseInt(mQ[1]);cuotaTotal=parseInt(mQ[2]);}
    // USD al final
    var moneda='ARS',monto=0;
    var mUSD=resto.match(/USD\s+([\d.,]+)\s*$/);
    if(mUSD){moneda='USD';monto=parseMonto(mUSD[1]);}
    else{
      var mM=resto.match(/([\d]+[\d.]*,\d{2})\s*$/);
      if(mM) monto=parseMonto(mM[1]);
    }
    if(monto===0) return;
    // Descripción limpia
    var desc=resto;
    desc=desc.replace(/C\.\d{2}\/\d{2}/gi,'');
    desc=desc.replace(/USD\s+[\d.,]+/gi,'');
    desc=desc.replace(/([\d]+[\d.]*,\d{2})\s*$/,'');
    desc=desc.replace(/\s+\d{6}\s*/g,' ');
    desc=desc.replace(/\s+/g,' ').trim();
    if(desc.length<2) return;
    result.consumos.push({
      fecha:fecha,descripcion:desc,monto:monto,moneda:moneda,
      categoria:guessCategory2(desc),cuotaActual:cuotaActual,cuotaTotal:cuotaTotal
    });
  });
  return result;
}


</script>
