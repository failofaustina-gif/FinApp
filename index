function processPDF(file){
  importState.pdfName=file.name;
  var statusEl=document.getElementById('import-status');
  var previewEl=document.getElementById('import-preview');
  if(statusEl) statusEl.innerHTML='<div style="background:var(--accentDim);border-radius:10px;padding:14px;font-size:.83rem;color:var(--accent)">⏳ Leyendo <strong>'+file.name+'</strong> con IA...</div>';
  if(previewEl) previewEl.innerHTML='';

  var reader=new FileReader();
  reader.onload=function(e){
    var base64=e.target.result.split(',')[1];
    importState.pdfBase64=base64;
    callClaudeWithPDF(base64,statusEl,previewEl);
  };
  reader.readAsDataURL(file);
}

async function callClaudeWithPDF(base64,statusEl,previewEl){
  try{
    if(!window.pdfjsLib){
      await new Promise(function(res,rej){
        var s=document.createElement('script');
        s.src='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js';
        s.onload=res;s.onerror=rej;
        document.head.appendChild(s);
      });
      window.pdfjsLib.GlobalWorkerOptions.workerSrc='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    }
    if(statusEl) statusEl.innerHTML='<div style="background:var(--accentDim);border-radius:10px;padding:12px;font-size:.83rem;color:var(--accent)">Extrayendo texto del PDF...</div>';
    var bin=atob(base64),arr=new Uint8Array(bin.length);
    for(var i=0;i<bin.length;i++) arr[i]=bin.charCodeAt(i);
    var pdf=await pdfjsLib.getDocument({data:arr}).promise;
    var fullText='';
    for(var p=1;p<=pdf.numPages;p++){
      var page=await pdf.getPage(p);
      var tc=await page.getTextContent();
      fullText+=tc.items.map(function(it){return it.str;}).join(' ')+'\n';
    }
    if(statusEl) statusEl.innerHTML='<div style="background:var(--accentDim);border-radius:10px;padding:12px;font-size:.83rem;color:var(--accent)">Analizando consumos...</div>';
    var parsed=parsearResumenTexto(fullText);
    importState.preview=parsed;
    renderPreview(parsed,statusEl,previewEl);
  }catch(err){
    if(statusEl) statusEl.innerHTML='<div style="background:var(--downBg);border-radius:10px;padding:14px;font-size:.83rem;color:var(--down)">Error al procesar el PDF: '+err.message+'</div>';
    console.error('importPDF error',err);
  }
}

function parseMonto(str){
  str=String(str||'').replace(/\s/g,'');
  // Formato arg: 1.566.725,99
  if(/^\d{1,3}(\.\d{3})*(,\d{1,2})?$/.test(str))
    return parseFloat(str.replace(/\./g,'').replace(',','.'));
  return parseFloat(str.replace(/,/g,''))||0;
}

