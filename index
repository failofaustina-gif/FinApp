async function fetchQ(sym){
  const PROXIES=[
    u=>`https://api.allorigins.win/raw?url=${encodeURIComponent(u)}`,
    u=>`https://corsproxy.io/?url=${encodeURIComponent(u)}`,
    u=>`https://proxy.cors.sh/${u}`,
  ];
  const url=`https://query1.finance.yahoo.com/v8/finance/chart/${sym}?interval=1d&range=1mo`;
  for(const proxy of PROXIES){
    try{
      const r=await fetch(proxy(url),{signal:AbortSignal.timeout(5000)});
      if(!r.ok)continue;
      const j=await r.json();
      const m=j?.chart?.result?.[0]?.meta;
      if(!m)continue;
      const price=m.regularMarketPrice||0,prev=m.chartPreviousClose||price;
      return{price:+price.toFixed(2),change:+(price-prev).toFixed(2),changePct:+(prev>0?(price-prev)/prev*100:0).toFixed(2),
        currency:m.currency||'USD',high:m.regularMarketDayHigh||price,low:m.regularMarketDayLow||price,
        history:(j?.chart?.result?.[0]?.indicators?.quote?.[0]?.close||[]).filter(Boolean)};
    }catch(e){continue;}
  }
  console.warn('fetchQ',sym,'todos los proxies fallaron');return null;
}
async function fetchN(sym){
