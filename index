// IMPORTADOR BALANZ ────────────────────────────────────────────────────────
function importBalanz(input){
  var file=input.files[0];
  if(!file)return;
  var reader=new FileReader();
  reader.onload=function(e){
    try{
      var data=new Uint8Array(e.target.result);
      var wb=XLSX.read(data,{type:'array'});
      var ws=wb.Sheets[wb.SheetNames[0]];
      var rows=XLSX.utils.sheet_to_json(ws,{header:1});
      if(!rows||rows.length<2){alert('No se encontraron datos en el archivo.');return;}
      // Mapear columnas
      var header=rows[0];
      var idxTicker=header.indexOf('Ticker');
      var idxTipo=header.indexOf('Tipo de Instrumento');
      var idxDesc=header.indexOf('Descripcion');
      var idxNom=header.indexOf('Nominales');
      var idxPrecio=header.indexOf('Precio');
      var idxPrecioCompra=header.indexOf('Precio promedio de compra');
      var idxValAct=header.indexOf('Valor actual');
      var idxValIni=header.indexOf('Valor inicial');
      var idxRend=header.indexOf('Porcentaje de rendimiento');
      var idxMoneda=header.indexOf('Moneda');
      var imported=[];
      for(var i=1;i<rows.length;i++){
        var row=rows[i];
        if(!row||!row[idxTicker])continue;
        var ticker=String(row[idxTicker]||'').trim();
        var tipo=String(row[idxTipo]||'').trim();
        var desc=String(row[idxDesc]||'').trim();
        var nominales=parseFloat(row[idxNom])||0;
        var precio=parseFloat(row[idxPrecio])||0;
        var precioCompra=parseFloat(row[idxPrecioCompra])||0;
        var valAct=parseFloat(row[idxValAct])||0;
        var valIni=parseFloat(row[idxValIni])||0;
        var monedaStr=String(row[idxMoneda]||'').toLowerCase();
        var moneda=(monedaStr.includes('dollar')||monedaStr.includes('dolar')||monedaStr.includes('usd'))?'USD':'ARS';
        // Tipo mapeado
        var tipoMap={'Bonos':'Bono','Letras':'Bono','Corporativos':'Bono','Acciones':'Accion','Cedears':'CEDEAR','FCI':'FCI'};
        var tipoFinal=tipoMap[tipo]||tipo;
        imported.push({
          id:Date.now().toString()+i,
          simbolo:ticker,
          tipo:tipoFinal,
          cantidad:String(nominales),
          precioCompra:String(precioCompra.toFixed(4)),
          precioActual:String(precio),
          comision:'0.6',
          moneda:moneda,
          descripcion:desc
        });
      }
      if(!imported.length){alert('No se encontraron instrumentos.');return;}
      // Confirmar
      var msg='Se importaron '+imported.length+' instrumentos desde Balanz:\n\n'+
        imported.map(function(inv){return inv.simbolo+' ('+inv.tipo+') - '+inv.cantidad+' nominales - '+inv.moneda;}).join('\n')+
        '\n\n¿Agregar a Mis inversiones?';
      if(!confirm(msg))return;
      // Agregar (evitar duplicados por ticker)
      var existentes=S.inversiones.map(function(i){return i.simbolo;});
      var agregados=0,actualizados=0;
      imported.forEach(function(inv){
        var idx=S.inversiones.findIndex(function(i){return i.simbolo===inv.simbolo;});
        if(idx>=0){
          // Actualizar precio actual
          S.inversiones[idx].precioActual=inv.precioActual;
          S.inversiones[idx].moneda=inv.moneda;
          actualizados++;
        } else {
          S.inversiones.push(inv);
          agregados++;
        }
      });
      sv('inversiones',S.inversiones);
      alert('Importacion completada:\n'+agregados+' nuevos agregados\n'+actualizados+' precios actualizados');
      input.value='';
      rPlanC();
    }catch(err){
      alert('Error al leer el archivo: '+err.message);
      console.error(err);
    }
  };
  reader.readAsArrayBuffer(file);
}

