  .ob-type:hover{border-color:var(--accent2)}
  .ob-type.sel{border-color:var(--accent);background:var(--accentDim)}
  .ob-type-icon{font-size:1.5rem;margin-bottom:5px}
  .ob-type-label{font-size:.85rem;font-weight:700;color:var(--ink)}
  .ob-type-sub{font-size:.72rem;color:var(--ink3);margin-top:2px}
