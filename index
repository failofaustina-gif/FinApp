function confirmarImport(){
  var data=importState.preview;
  if(!data) return;

  // 1. Crear/actualizar tarjeta
  var nombre=document.getElementById('imp-tnombre').value.trim()||'Tarjeta';
  var saldo=parseFloat(document.getElementById('imp-tsaldo').value)||0;
  var cierre=parseInt(document.getElementById('imp-tcierre').value)||1;
  var venc=parseInt(document.getElementById('imp-tvenc').value)||10;

  var existente=S.tarjetas.find(function(t){return t.nombre.toLowerCase().includes(nombre.toLowerCase().split(' ')[0]);});
  if(existente){
    existente.saldo=saldo.toString();
    existente.cierre=cierre;
    existente.vencimiento=venc;
  } else {
    S.tarjetas.push({id:Date.now().toString(),nombre:nombre,limite:'',saldo:saldo.toString(),cierre:cierre,vencimiento:venc,cuotas:[]});
  }
  sv('tarjetas',S.tarjetas);

  // 2. Importar consumos seleccionados como gastos variables
  var seleccionados=(data.consumos||[]).filter(function(c){return c._sel;});
  var nuevos=seleccionados.map(function(c){
    return {
      id:(Date.now()+Math.random()).toString(),
      nombre:c.descripcion+(c.cuotaTotal>1?' ('+c.cuotaActual+'/'+c.cuotaTotal+')':''),
      monto:c.moneda==='USD'?(c.monto*S.macro.tipoCambio).toFixed(0):c.monto.toFixed(0),
      fecha:c.fecha,
      categoria:c.categoria
    };
  });
  S.vars=S.vars.concat(nuevos);
  sv('vars',S.vars);

  // 3. Feedback y limpiar
  importState.preview=null;
  importState.pdfBase64=null;
  var status=document.getElementById('import-status');
  if(status) status.innerHTML='<div style="background:var(--upBg);border:1px solid var(--up)40;border-radius:10px;padding:14px;font-size:.875rem;color:var(--up);font-weight:600">✓ Importados '+seleccionados.length+' consumos y datos de tarjeta. Revisalos en Tarjetas y Variables.</div>';
  var prev=document.getElementById('import-preview');
  if(prev) prev.innerHTML='<div style="display:flex;gap:10px;margin-top:12px">'+
    '<button onclick="setFT(\'tarjetas\',document.querySelector(\'.ft:nth-child(5)\'))" style="flex:1;background:var(--accentDim);color:var(--accent);border:1px solid var(--accent2);border-radius:9px;padding:10px;font-size:.83rem;font-weight:600;cursor:pointer;font-family:DM Sans,sans-serif">Ver tarjeta →</button>'+
    '<button onclick="setFT(\'variables\',document.querySelector(\'.ft:nth-child(3)\'))" style="flex:1;background:var(--accentDim);color:var(--accent);border:1px solid var(--accent2);border-radius:9px;padding:10px;font-size:.83rem;font-weight:600;cursor:pointer;font-family:DM Sans,sans-serif">Ver gastos variables →</button>'+
  '</div>';
}

