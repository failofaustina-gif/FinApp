function calcTIR(cups,p){let r=.04;for(let it=0;it<200;it++){let f=-p,d=0;cups.forEach((c,i)=>{const cf=c.i+c.a,t=(i+1)*.5;f+=cf/Math.pow(1+r,t);d-=t*cf/Math.pow(1+r,t+1);});const nr=r-f/d;if(Math.abs(nr-r)<1e-8){r=nr;break;}r=nr;}return r*2*100;}
function calcDur(cups,tir){const r=tir/100/2;let wt=0,pv=0;cups.forEach((c,i)=>{const cf=c.i+c.a,t=(i+1)*.5,pvc=cf/Math.pow(1+r,t);wt+=t*pvc;pv+=pvc;});return pv>0?(wt/pv)/(1+r):0;}
