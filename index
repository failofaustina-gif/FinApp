// ── GASTOS OPERATIVOS ──────────────────────────────────────────────────────
function rEmpGastos(el){
  var gastos=loadEmp('gastos');
  var gastosMes=loadEmp('gastos_hist'); // histórico por mes
  var totG=gastos.reduce(function(s,g){return s+toN(g.monto);},0);

  // Agrupar por categoría
  var porCat={};
  gastos.forEach(function(g){var c=g.categoria||'Otros gastos';porCat[c]=(porCat[c]||0)+toN(g.monto);});
  var cats=Object.keys(porCat);

  // Dona SVG
  var COLORS2=['#2d6a4f','#1a5fa0','#c47c1a','#6d3fc0','#c0392b','#52b788'];
  var donaHTML='';
  if(cats.length>1&&totG>0){
    var paths2='',ang2=-Math.PI/2;
    cats.forEach(function(c,i){
      var pct=porCat[c]/totG,end=ang2+pct*Math.PI*2;
      var x1=60+50*Math.cos(ang2),y1=60+50*Math.sin(ang2),x2=60+50*Math.cos(end),y2=60+50*Math.sin(end);
      paths2+='<path d="M60,60 L'+x1.toFixed(1)+','+y1.toFixed(1)+' A50,50 0 '+(pct>.5?1:0)+',1 '+x2.toFixed(1)+','+y2.toFixed(1)+' Z" fill="'+COLORS2[i%COLORS2.length]+'" opacity=".85"/>';
      ang2=end;
    });
    paths2+='<circle cx="60" cy="60" r="24" fill="var(--bg)"/>';
    donaHTML='<div class="card" style="margin-bottom:12px"><div class="ct">Distribucion por categoria</div>'+
      '<div style="display:flex;align-items:center;gap:18px;flex-wrap:wrap">'+
      '<svg viewBox="0 0 120 120" width="110" height="110">'+paths2+'</svg>'+
      '<div style="flex:1;min-width:160px">'+
        cats.map(function(c,i){return '<div style="display:flex;align-items:center;gap:7px;margin-bottom:5px;font-size:.8rem"><div style="width:8px;height:8px;border-radius:2px;background:'+COLORS2[i%COLORS2.length]+';flex-shrink:0"></div><span style="flex:1;color:var(--ink2)">'+c+'</span><span style="font-weight:700">'+Math.round(porCat[c]/totG*100)+'%</span></div>';}).join('')+
      '</div></div></div>';
  }

  var html='<div class="card" style="margin-bottom:12px"><div class="ct">Total gastos operativos</div>';
  html+='<div style="font-family:Fraunces,serif;font-size:1.8rem;font-weight:700;color:var(--down)">-'+fA(totG)+'/mes</div></div>';
  html+=donaHTML;
  html+='<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px"><span class="fst">Detalle</span><button class="ab" id="btn-add-gas" data-lista="gastos">+ Agregar</button></div>';
  html+='<p style="font-size:.73rem;color:var(--ink3);margin-bottom:10px">Costos fijos y variables del dia a dia.</p>';
  html+=gastos.length?gastos.map(function(i){return empCard(i,'gastos',CAT_GAS,false);}).join(''):'<div class="empty">Sin gastos cargados.</div>';

  // Guardar snapshot del mes actual para comparacion
  var mesActual=new Date().toISOString().slice(0,7); // "2025-01"
  var hist=JSON.parse(localStorage.getItem('fa_emp_gastos_hist')||'{}');
  if(totG>0) hist[mesActual]=totG;
  localStorage.setItem('fa_emp_gastos_hist',JSON.stringify(hist));

  // Comparacion mes a mes
  var meses=Object.keys(hist).sort();
  if(meses.length>1){
    html+='<div class="card" style="margin-top:14px"><div class="ct">Evolucion mensual</div>';
    var maxH=Math.max.apply(null,meses.map(function(m){return hist[m];}));
    html+='<div style="display:flex;align-items:flex-end;gap:6px;height:80px;margin-bottom:8px">';
    meses.slice(-6).forEach(function(m){
      var h=(hist[m]/maxH)*100;
      var esCurrent=m===mesActual;
      html+='<div style="flex:1;display:flex;flex-direction:column;align-items:center;height:100%">';
      html+='<div style="width:100%;height:'+h+'%;background:'+(esCurrent?'var(--down)':'var(--bg3)')+';border-radius:4px 4px 0 0;min-height:4px"></div>';
      html+='<div style="font-size:.6rem;color:var(--ink3);margin-top:3px">'+m.slice(5)+'</div>';
      html+='</div>';
    });
    html+='</div>';
    if(meses.length>=2){
      var ultimo=hist[meses[meses.length-1]],anterior=hist[meses[meses.length-2]];
      var diff=ultimo-anterior,pct=anterior>0?(diff/anterior*100):0;
      html+='<div style="font-size:.82rem;color:'+(diff>=0?'var(--down)':'var(--up)')+';font-weight:600">'+(diff>=0?'▲ Subieron':'▼ Bajaron')+' '+Math.abs(pct).toFixed(1)+'% vs mes anterior</div>';
    }
    html+='</div>';
  }
  el.innerHTML=html;
  attachEmpEvents(el);
}

