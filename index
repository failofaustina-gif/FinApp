function calcFases(cap,ap1,t1,a1,ap2,t2,a2){
  var r1=t1/100/12, r2=t2/100/12, s=cap, res=[];
  for(var i=1;i<=a1*12;i++){s=s*(1+r1)+ap1;if(i%12===0)res.push({ano:i/12,saldo:Math.round(s),fase:1});}
  for(var i=1;i<=a2*12;i++){s=s*(1+r2)+ap2;if(s<0)s=0;if(i%12===0)res.push({ano:a1+i/12,saldo:Math.round(s),fase:2});}
  return res;
}

