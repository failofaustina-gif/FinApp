async function fetchMacroOficial(){
  const el=document.getElementById('macro-oficial');
  if(!el)return;
  el.innerHTML='<div style="font-size:.78rem;color:var(--ink3)">Cargando datos oficiales...</div>';
  const resultados={};
  // TC via dolarapi.com (CORS abierto)
  try{
    const r=await fetch('https://dolarapi.com/v1/dolares',{signal:AbortSignal.timeout(6000)});
    const j=await r.json();
    if(Array.isArray(j)){
      j.forEach(d=>{
        if(d.casa==='oficial')resultados.tcOficial={compra:d.compra,venta:d.venta};
        if(d.casa==='blue')resultados.tcBlue={compra:d.compra,venta:d.venta};
        if(d.casa==='bolsa'||d.casa==='mep')resultados.tcMEP={compra:d.compra,venta:d.venta};
        if(d.casa==='contadoconliqui'||d.casa==='ccl')resultados.tcCCL={compra:d.compra,venta:d.venta};
      });
    }
  }catch(e){
    // fallback: bluelytics
    try{
      const r2=await fetch('https://api.bluelytics.com.ar/v2/latest',{signal:AbortSignal.timeout(6000)});
      const j2=await r2.json();
      if(j2?.oficial)resultados.tcOficial={compra:j2.oficial.value_buy,venta:j2.oficial.value_sell};
      if(j2?.blue)resultados.tcBlue={compra:j2.blue.value_buy,venta:j2.blue.value_sell};
    }catch(e2){console.warn('TC fallback error',e2.message);}
  }
  // Inflacion INDEC - variacion porcentual mensual IPC Nacional (indice nivel general)
  try{
    // Serie: IPC Nacional Nivel General - variacion mensual
    const url3='https://apis.datos.gob.ar/series/api/series/?ids=148.3_INIVELNAL_DICI_M_26&representation_mode=percent_change&limit=3&format=json';
    const r3=await fetch(url3,{signal:AbortSignal.timeout(6000)});
    const j3=await r3.json();
    const datos=j3?.data||[];
    if(datos.length>=1){
      const ult=datos[datos.length-1];
      // valor ya viene como fraccion (0.028 = 2.8%), multiplicar por 100
      const valorPct=ult[1]*100;
      resultados.inflacion={valor:valorPct,fecha:ult[0]};
    }
  }catch(e){console.warn('INDEC error',e.message);}
  // Render
  if(!el)return;
  const tcO=resultados.tcOficial,tcB=resultados.tcBlue,tcM=resultados.tcMEP,tcC=resultados.tcCCL;
  const inf=resultados.inflacion;
  let html2='<div class="ct">Datos oficiales y de mercado</div>';
  if(tcO||tcB){
    html2+='<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:8px;margin-bottom:12px">';
    if(tcO)html2+='<div style="background:var(--bg);border-radius:8px;padding:10px"><div style="font-size:.62rem;color:#2d6a4f;font-weight:600;margin-bottom:3px">DOLAR OFICIAL</div><div style="font-size:1.1rem;font-weight:700">$'+(tcO.venta?.toFixed(0)||'?')+'</div><div style="font-size:.68rem;color:var(--ink3)">Compra $'+(tcO.compra?.toFixed(0)||'?')+'</div></div>';
    if(tcB)html2+='<div style="background:var(--bg);border-radius:8px;padding:10px"><div style="font-size:.62rem;color:#c47c1a;font-weight:600;margin-bottom:3px">DOLAR BLUE</div><div style="font-size:1.1rem;font-weight:700">$'+(tcB.venta?.toFixed(0)||'?')+'</div><div style="font-size:.68rem;color:var(--ink3)">Compra $'+(tcB.compra?.toFixed(0)||'?')+'</div></div>';
    if(tcM)html2+='<div style="background:var(--bg);border-radius:8px;padding:10px"><div style="font-size:.62rem;color:#1a5fa0;font-weight:600;margin-bottom:3px">DOLAR MEP</div><div style="font-size:1.1rem;font-weight:700">$'+(tcM.venta?.toFixed(0)||'?')+'</div><div style="font-size:.68rem;color:var(--ink3)">Compra $'+(tcM.compra?.toFixed(0)||'?')+'</div></div>';
    if(tcC)html2+='<div style="background:var(--bg);border-radius:8px;padding:10px"><div style="font-size:.62rem;color:#6d3fc0;font-weight:600;margin-bottom:3px">DOLAR CCL</div><div style="font-size:1.1rem;font-weight:700">$'+(tcC.venta?.toFixed(0)||'?')+'</div><div style="font-size:.68rem;color:var(--ink3)">Compra $'+(tcC.compra?.toFixed(0)||'?')+'</div></div>';
    html2+='</div>';
    // Actualizar macro con TC oficial si está disponible
    if(tcO&&tcO.venta){
      html2+='<button style="background:var(--accentDim);color:#2d6a4f;border:1px solid #52b788;border-radius:7px;padding:5px 12px;font-size:.76rem;font-weight:600;cursor:pointer;font-family:DM Sans,sans-serif;margin-bottom:10px" onclick="S.macro.tipoCambio='+tcO.venta.toFixed(0)+';svM();rMacro()">Usar TC oficial ($'+tcO.venta.toFixed(0)+') en mis calculos</button>';
    }
  }
  if(inf){
    html2+='<div style="background:var(--downBg);border-radius:8px;padding:12px;border:1px solid #c0392b30"><div style="font-size:.62rem;color:#c0392b;font-weight:600;margin-bottom:3px">INFLACION MENSUAL (INDEC · IPC Nacional)</div><div style="display:flex;align-items:baseline;gap:8px"><div style="font-family:Fraunces,serif;font-size:1.4rem;font-weight:700;color:#c0392b">'+(inf.valor?.toFixed(1)||'—')+'%</div><div style="font-size:.75rem;color:var(--ink3)">'+(inf.fecha||'')+'</div></div><button style="margin-top:7px;background:var(--downBg);color:#c0392b;border:1px solid #c0392b40;border-radius:7px;padding:4px 11px;font-size:.75rem;font-weight:600;cursor:pointer;font-family:DM Sans,sans-serif" onclick="S.macro.inflMensual='+(inf.valor?.toFixed(1)||3)+';svM();rMacro()">Usar este valor en mis calculos</button></div>';
  }
  if(!tcO&&!tcB&&!inf){
    html2+='<div style="font-size:.78rem;color:var(--ink3)">No se pudieron cargar datos en este momento. Verifica tu conexion.</div>';
  }
  html2+='<div style="font-size:.65rem;color:var(--ink3);margin-top:8px">Fuentes: DolarApi.com · apis.datos.gob.ar (INDEC)</div>';
  el.innerHTML=html2;
}

