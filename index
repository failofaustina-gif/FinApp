      '<div class="ri"><div class="rl">Real en USD</div><div class="rv" style="color:'+(rr>=0?'#2d6a4f':'#c0392b')+'">'+fP(rr)+'</div><div class="rs">vs inflacion USD ~3%</div></div>'+
      '<div class="ri"><div class="rl">Equiv. ARS real</div><div class="rv" style="color:#1a5fa0">'+fP(((1+tirN/100)/Math.pow(1+S.macro.devalMensual/100,cups.length*6)-1)*100)+'</div><div class="rs">Con deval. e inflacion</div></div>'+
    '</div>'+
    '<div class="niv" style="background:var(--downBg);border-color:#c0392b40;color:#c0392b">'+
      '<div style="font-size:.7rem;font-weight:600;margin-bottom:5px">Costo de no invertir USD '+capInv.toFixed(0)+' en 12 meses:</div>'+
      '<div class="niv-r"><span>Perdida en ARS (inflacion '+S.macro.inflMensual+'%/mes)</span><span style="font-weight:700">-'+fA(perdARS)+'</span></div>'+
      '<div class="niv-r"><span>Perdida en USD</span><span style="font-weight:700">-'+fU(perdARS/S.macro.tipoCambio)+'</span></div>'+
