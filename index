function selColorCat(el,color){
  document.querySelectorAll('.color-dot').forEach(function(d){d.classList.remove('sel');});
  el.classList.add('sel');
  document.getElementById('new-cat-color').value=color;
}
function saveNewCat(){
  var nombre=(document.getElementById('new-cat-nombre').value||'').trim();
  var color=document.getElementById('new-cat-color').value||'#7f8c8d';
  if(!nombre) return;
  var cats=getCategorias();
  if(cats.find(function(c){return c.nombre.toLowerCase()===nombre.toLowerCase();})){
    alert('Esa categoria ya existe');return;
  }
  cats.push({nombre:nombre,color:color});
  saveCategorias(cats);
  document.getElementById('add-cat-form').style.display='none';
  document.getElementById('new-cat-nombre').value='';
  // Re-render resumen
  rFinC();
}
function delCategoria(idx){
  var cats=getCategorias();
  if(!confirm('Eliminar categoria "'+cats[idx].nombre+'"?')) return;
  cats.splice(idx,1);
  saveCategorias(cats);
  rFinC();
}

