      '<button class="ctl-b" data-k="'+k+'" data-step="-'+step+'" data-max="'+max+'" onclick="doUpdC(this)">−</button>'+
      '<div class="ctl-t"><div class="ctl-f" id="cf-'+k+'" style="width:'+pct+'%"></div></div>'+
      '<button class="ctl-b" data-k="'+k+'" data-step="'+step+'" data-max="'+max+'" onclick="doUpdC(this)">+</button>'+
    '</div></div>';
}
function buildCtrlRetiro(k,label,max,step,display){
  var C=S.calcP;
  var val=C[k]||0;
  var pct=Math.min(100,val/max*100);
  return '<div class="ctl">'+
    '<div class="cth"><span class="ctl-l">'+label+'</span><span class="ctl-v" id="cl-'+k+'">'+display+'</span></div>'+
    '<div class="ctl-r">'+
      '<button class="ctl-b" data-k="'+k+'" data-step="-'+step+'" data-max="'+max+'" onclick="doUpdC(this)">−</button>'+
      '<div class="ctl-t"><div class="ctl-f" id="cf-'+k+'" style="width:'+pct+'%;background:#c47c1a"></div></div>'+
      '<button class="ctl-b" data-k="'+k+'" data-step="'+step+'" data-max="'+max+'" onclick="doUpdC(this)">+</button>'+
    '</div></div>';
}

function toggleCalcModo(){
  S.calcP.modo2fases=!S.calcP.modo2fases;
  if(!S.calcP.retiro)S.calcP.retiro=30000;
  rCalc();
}

function doUpdC(btn){
  var C=S.calcP;
  var k=btn.getAttribute('data-k');
  var step=parseFloat(btn.getAttribute('data-step'));
  var max=parseFloat(btn.getAttribute('data-max'));
  var mins={tasa:1,anos:1,tasa2:1,anos2:1,capital:0,aporte:0,retiro:0};
  C[k]=Math.max(mins[k]||0, Math.min(max, (C[k]||0)+step));
  var fmts={
    capital:fA,aporte:fA,retiro:function(v){return fA(v)+'/mes';},
    tasa:function(v){return v+'% anual';},
    anos:function(v){return v+(v===1?' ano':' anos');},
    tasa2:function(v){return v+'% anual';},
    anos2:function(v){return v+(v===1?' ano':' anos');}
  };
  var lbl=document.getElementById('cl-'+k);
  if(lbl)lbl.textContent=fmts[k](C[k]);
  var fill=document.getElementById('cf-'+k);
  if(fill)fill.style.width=Math.min(100,(C[k]||0)/max*100)+'%';
  updCC();
}

function updCC(){
  var C=S.calcP;
  var m2=C.modo2fases;
  var ap2=m2?-(C.retiro||0):0;
  var data=calcFases(C.capital,C.aporte,C.tasa,C.anos,ap2,C.tasa2||8,m2?C.anos2:0);
  var final=data.length?data[data.length-1].saldo:C.capital;
  var totalAp=C.capital+C.aporte*C.anos*12;
  var gan=Math.max(0,final-totalAp);
  var el; 
  var tc=S.macro.tipoCambio||1200;
  var fmtCalc=function(v){return S.moneda==='USD'?'USD '+(v/tc).toLocaleString('es-AR',{minimumFractionDigits:2,maximumFractionDigits:2}):fA(v);};
  el=document.getElementById('cv-f');if(el)el.textContent=fmtCalc(final);
  el=document.getElementById('cv-a');if(el)el.textContent=fmtCalc(totalAp);
  el=document.getElementById('cv-g');if(el)el.textContent=fmtCalc(gan);
  el=document.getElementById('cv-m');if(el)el.textContent=(totalAp>0?(final/totalAp).toFixed(1):'1.0')+'x';
  // Transición (capital al inicio de fase 2)
  if(m2){
    var fase1=data.filter(function(d){return d.fase===1;});
    var capRetiro=fase1.length?fase1[fase1.length-1].saldo:0;
    var duracion=capRetiro>0&&C.retiro>0?capRetiro/(C.retiro||1)/12:0;
    var tr=document.getElementById('c-transicion');
    if(tr)tr.innerHTML=
      '<div class="ct" style="color:#c47c1a">Al inicio del retiro</div>'+
      '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px">'+
        '<div style="background:var(--card);border-radius:8px;padding:10px"><div style="font-size:.62rem;color:var(--ink3);margin-bottom:2px">Capital acumulado</div><div style="font-family:Fraunces,serif;font-size:1.1rem;font-weight:700;color:#2d6a4f">'+fA(capRetiro)+'</div></div>'+
        '<div style="background:var(--card);border-radius:8px;padding:10px"><div style="font-size:.62rem;color:var(--ink3);margin-bottom:2px">Retiro mensual</div><div style="font-family:Fraunces,serif;font-size:1.1rem;font-weight:700;color:#c47c1a">'+fA(C.retiro||0)+'</div></div>'+
        '<div style="background:var(--card);border-radius:8px;padding:10px"><div style="font-size:.62rem;color:var(--ink3);margin-bottom:2px">Duracion estimada</div><div style="font-family:Fraunces,serif;font-size:1.1rem;font-weight:700">'+(duracion>0?duracion.toFixed(1)+' anos':'∞')+'</div></div>'+
      '</div>';
  }
  // Gráfico
  var chart=document.getElementById('c-chart');
  if(chart&&data.length){
    var mx=Math.max.apply(null,data.map(function(d){return d.saldo;}));
    chart.innerHTML=data.map(function(d,i){
      var h=mx>0?(d.saldo/mx)*100:0;
      var ap=totalAp*(d.ano/(data[data.length-1].ano||1));
      var gp=d.saldo>0?Math.min(100,((d.saldo-Math.min(ap,d.saldo))/d.saldo)*100):0;
      var color=d.fase===2?'#c47c1a':'#2d6a4f';
      return '<div class="bco">'+
        '<div class="bin2" style="height:'+h+'%">'+
          '<div style="width:100%;height:'+gp+'%;background:'+color+'"></div>'+
        '</div>'+
        ((i===0||(i+1)%5===0)?'<div class="blb">'+d.ano+'a</div>':'<div class="blb"></div>')+
      '</div>';
    }).join('');
  }
  // Tabla
  var tbl=document.getElementById('c-tbl');
  if(tbl){
    var rows='<thead><tr><th>Ano</th>'+(m2?'<th>Fase</th>':'')+
      '<th style="text-align:right">Saldo</th>'+
      '<th style="text-align:right">Ganancia</th></tr></thead><tbody>';
    data.forEach(function(d){
      var base=C.capital+C.aporte*Math.min(d.ano,C.anos)*12;
      var g=Math.max(0,d.saldo-base);
      var faseCell=d.fase===2?
        '<td><span style="color:#c47c1a;font-size:.7rem;font-weight:600">Retiro</span></td>':
        '<td><span style="color:#2d6a4f;font-size:.7rem;font-weight:600">Acum.</span></td>';
      rows+='<tr'+(d.fase===2?' style="background:#c47c1a08"':'')+'>'+
        '<td>Ano '+d.ano+'</td>'+
        (m2?faseCell:'')+
        '<td style="text-align:right;font-weight:600">'+fA(d.saldo)+'</td>'+
        '<td style="text-align:right;color:'+(d.fase===2?'#c47c1a':'#2d6a4f')+'">'+fA(g)+'</td>'+
      '</tr>';
    });
    tbl.innerHTML=rows+'</tbody>';
  }
}

