function updB(sym){
  const cups=sym.includes('30')?C30:C35;
  const tI=cups.reduce((s,c)=>s+c.i,0),tA=cups.reduce((s,c)=>s+c.a,0),tF=tI+tA;
  const pN=+document.getElementById('b-p')?.value||45,pb=pN>100?pN/10:pN;
  const lam=+document.getElementById('b-l')?.value||1,com=+document.getElementById('b-bk')?.value||.006;
  const pe=document.getElementById('b-pe');if(pe)pe.textContent='Efectivo: USD '+pb.toFixed(2);
  const capInv=pb*lam,comC=capInv*com,comV=tF*lam*com;
  const ganI=tI*lam,ganC=(tA-pb)*lam,ganB=(tF-pb)*lam,ganN=ganB-comC-comV;
  const tirB=calcTIR(cups,pb),tirN=calcTIR(cups,pb+comC/lam),dur=calcDur(cups,tirB);
  const rr=((1+tirN/100)/1.03-1)*100;
