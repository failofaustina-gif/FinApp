<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>FinApp — Tu asesora financiera digital</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f5f0e8;--bg2:#ede8df;--card:#fff;--border:#ddd8ce;
  --ink:#1a1814;--ink2:#5a5650;--ink3:#9a9690;
  --accent:#2d6a4f;--accent2:#52b788;--accent3:#b7e4c7;--accentDim:#2d6a4f14;
  --up:#2d6a4f;--upBg:#2d6a4f12;--down:#c0392b;--downBg:#c0392b12;
  --warn:#c47c1a;--warnBg:#c47c1a12;--info:#1a5fa0;--infoBg:#1a5fa012;
  --r:12px;--r2:16px;--shadow:0 2px 12px rgba(0,0,0,.06);--shadow2:0 8px 32px rgba(0,0,0,.1);
}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--ink);min-height:100vh;overflow-x:hidden}
nav{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(245,240,232,.95);backdrop-filter:blur(16px);border-bottom:1px solid var(--border)}
.nav-inner{max-width:1100px;margin:0 auto;padding:0 24px;height:56px;display:flex;align-items:center;justify-content:space-between}
.nav-logo{font-family:'Fraunces',serif;font-size:1.2rem;font-weight:700;color:var(--accent)}
.nav-tabs{display:flex;gap:3px;flex-wrap:wrap}
.nt{background:none;border:none;font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:500;color:var(--ink3);padding:5px 11px;border-radius:7px;cursor:pointer;transition:all .2s}
.nt:hover{background:var(--bg2);color:var(--ink)}
.nt.on{background:var(--accentDim);color:var(--accent);font-weight:600}
main{max-width:1100px;margin:0 auto;padding:74px 24px 60px}
.pg{display:none;animation:fi .25s ease}
.pg.on{display:block}
@keyframes fi{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
h1.pt{font-family:'Fraunces',serif;font-size:1.85rem;font-weight:700;letter-spacing:-.04em;color:var(--ink);margin-bottom:4px}
.psub{font-size:.86rem;color:var(--ink3);margin-bottom:20px}
.sl{font-size:.68rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--ink3);margin-bottom:8px}
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);padding:18px;box-shadow:var(--shadow)}
.ct{font-size:.66rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--ink3);margin-bottom:10px}
.hero{background:var(--accent);border-radius:20px;padding:30px;margin-bottom:18px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:-40px;right:-40px;width:180px;height:180px;border-radius:50%;background:rgba(255,255,255,.06)}
.hero h1{font-family:'Fraunces',serif;font-size:1.9rem;font-weight:700;color:#fff;line-height:1.15;margin-bottom:8px}
.hero h1 em{font-style:italic;color:var(--accent3)}
.hero p{font-size:.88rem;color:rgba(255,255,255,.75);line-height:1.6;margin-bottom:18px;max-width:440px}
.bhero{display:inline-flex;align-items:center;gap:7px;background:rgba(255,255,255,.2);color:#fff;border:1px solid rgba(255,255,255,.3);border-radius:9px;padding:8px 16px;font-size:.83rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif}
.bhero:hover{background:rgba(255,255,255,.3)}
.tg{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:9px;margin-bottom:20px}
.tr{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);padding:13px 15px;display:flex;align-items:center;gap:11px;cursor:pointer;transition:all .2s}
.tr:hover{border-color:var(--accent2);transform:translateY(-1px);box-shadow:var(--shadow2)}
.tn{font-size:.88rem;font-weight:600;color:var(--ink);margin-bottom:1px}
.ts{font-size:.73rem;color:var(--ink3)}
.rg{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:9px;margin-bottom:18px}
.rc{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);padding:13px;border-left:3px solid}
.rniv{font-size:.83rem;font-weight:700;margin-bottom:3px}
.rdesc{font-size:.73rem;color:var(--ink2);margin-bottom:4px}
.rinst{font-size:.68rem;color:var(--ink3)}
.disc{background:var(--bg2);border-radius:var(--r);padding:11px;font-size:.71rem;color:var(--ink3);line-height:1.6}
/* MERCADO */
.mts{display:flex;gap:7px;margin-bottom:16px;flex-wrap:wrap}
.mt{background:var(--card);border:1px solid var(--border);border-radius:7px;padding:5px 13px;font-size:.8rem;font-weight:500;color:var(--ink3);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s}
.mt.on{background:var(--accentDim);border-color:var(--accent2);color:var(--accent);font-weight:600}
.ql{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);overflow:hidden}
.qr{display:grid;grid-template-columns:120px 1fr 70px 105px 85px 36px;align-items:center;gap:9px;padding:11px 15px;border-bottom:1px solid var(--bg2);cursor:pointer;transition:background .15s}
.qr:last-child{border-bottom:none}
.qr:hover{background:var(--bg)}
.qrh{font-size:.65rem;font-weight:600;color:var(--ink3);text-transform:uppercase;letter-spacing:.06em;background:var(--bg);cursor:default}
.qrh:hover{background:var(--bg)}
.qsym{font-size:.88rem;font-weight:700}
.qnm{font-size:.73rem;color:var(--ink3)}
.qp{font-size:.88rem;font-weight:700;text-align:right}
.qch{font-size:.73rem;font-weight:600;padding:2px 7px;border-radius:5px;text-align:center}
.upb{background:var(--upBg);color:var(--up)}
.dnb{background:var(--downBg);color:var(--down)}
.qfv{font-size:.95rem;cursor:pointer;padding:4px;color:var(--ink3);border:none;background:none;font-family:inherit;transition:color .2s}
.qfv.on{color:var(--warn)}
/* DETALLE */
.bk{display:inline-flex;align-items:center;gap:5px;font-size:.83rem;font-weight:500;color:var(--accent);cursor:pointer;margin-bottom:12px;background:none;border:none;font-family:'DM Sans',sans-serif;padding:0}
.dh{font-family:'Fraunces',serif;font-size:1.65rem;font-weight:700;color:var(--ink)}
.pc{border-radius:var(--r2);padding:18px;margin-bottom:13px;color:#fff}
.plb{font-size:.7rem;opacity:.7;font-weight:600;letter-spacing:.05em;margin-bottom:3px}
.pa{font-family:'Fraunces',serif;font-size:1.9rem;font-weight:700;margin-bottom:5px}
.pch{font-size:.85rem;font-weight:600}
.pdl{font-size:.7rem;opacity:.6;margin-top:2px}
/* REND REAL */
.rb{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);padding:16px;margin-bottom:13px}
.rg3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;margin-bottom:11px}
.ri{background:var(--bg);border-radius:9px;padding:11px;text-align:center}
.rl{font-size:.63rem;color:var(--ink3);font-weight:500;margin-bottom:3px;text-transform:uppercase;letter-spacing:.04em}
.rv{font-family:'Fraunces',serif;font-size:1.2rem;font-weight:700}
.rs{font-size:.63rem;color:var(--ink3);margin-top:2px}
.niv{border-radius:9px;padding:11px;border:1px solid}
.niv-r{display:flex;justify-content:space-between;font-size:.8rem;margin-bottom:3px}
/* NOTICIAS */
.nbar{background:#fff8e1;border:1px solid #ffe082;border-radius:7px;padding:9px 11px;margin-bottom:11px;font-size:.76rem;color:#7c5e00;line-height:1.5}
.nc{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:11px 13px;margin-bottom:6px;display:flex;gap:9px;align-items:flex-start;cursor:pointer;transition:all .2s;text-decoration:none;color:inherit}
.nc:hover{border-color:var(--accent2)}
.nc.f{border-color:var(--accent2);background:var(--upBg)}
.nti{font-size:.83rem;font-weight:600;color:var(--ink);margin-bottom:4px;line-height:1.4}
.nfo{display:flex;justify-content:space-between}
.nfu{font-size:.7rem;color:var(--accent);font-weight:600}
.nfe{font-size:.7rem;color:var(--ink3)}
/* BONO */
.bin{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;margin-bottom:13px}
.ig{display:flex;flex-direction:column;gap:4px}
.ig label{font-size:.7rem;font-weight:500;color:var(--ink2)}
.ig input,.ig select{background:var(--bg);border:1px solid var(--border);border-radius:7px;padding:7px 9px;font-size:.86rem;font-family:'DM Sans',sans-serif;color:var(--ink);outline:none}
.ig input:focus,.ig select:focus{border-color:var(--accent)}
.kr{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;margin-bottom:13px}
.kp{border-radius:var(--r);padding:12px;color:#fff;text-align:center}
.kl{font-size:.63rem;opacity:.75;font-weight:600;letter-spacing:.04em;margin-bottom:3px}
.kv{font-family:'Fraunces',serif;font-size:1.25rem;font-weight:700}
.ks{font-size:.63rem;opacity:.6;margin-top:2px}
.cft{width:100%;border-collapse:collapse;font-size:.78rem}
.cft th{text-align:left;padding:6px 9px;font-size:.63rem;font-weight:600;color:var(--ink3);text-transform:uppercase;letter-spacing:.06em;border-bottom:1px solid var(--border)}
.cft td{padding:6px 9px;border-bottom:1px solid var(--bg2)}
.cft tr:nth-child(even) td{background:var(--bg)}
.cft tr.tot td{background:var(--accent3)!important;font-weight:700;color:var(--accent)}
/* ESC */
.eg{display:grid;grid-template-columns:1fr 1fr 1fr;gap:11px;margin-bottom:11px}
.ec{border-radius:var(--r2);border:2px solid;overflow:hidden}
.eh{padding:9px 11px;color:#fff}
.ebt{font-size:.83rem;font-weight:700}
.eb{padding:11px;background:var(--card)}
.eir{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:9px}
.es{background:var(--bg);border-radius:7px;padding:8px}
.esl{font-size:.63rem;color:var(--ink3);margin-bottom:1px}
.esv{font-size:.83rem;font-weight:700;color:var(--ink)}
.eg2{border-radius:7px;padding:10px;text-align:center}
.egl{font-size:.63rem;font-weight:600;letter-spacing:.06em;color:var(--ink3);margin-bottom:3px}
.egv{font-family:'Fraunces',serif;font-size:1.25rem;font-weight:700}
.egp{font-size:.7rem;margin-top:2px}
/* BROKER */
.bs{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:9px}
.bb{padding:5px 11px;border-radius:7px;border:1px solid var(--border);background:var(--card);font-size:.76rem;font-weight:500;color:var(--ink3);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s}
.bb.on{background:var(--accentDim);border-color:var(--accent2);color:var(--accent);font-weight:600}
/* RESUMEN BONO */
.rss{margin-bottom:11px;padding-bottom:11px;border-bottom:1px solid var(--bg2)}
.rss:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0}
.rst{font-size:.63rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--ink3);margin-bottom:6px}
.rrow{display:flex;justify-content:space-between;align-items:center;padding:3px 0;font-size:.81rem}
.rtot{font-weight:700;border-top:1px solid var(--border);padding-top:6px;margin-top:2px}
.gb{border-radius:var(--r);padding:13px;margin-top:3px}
.gsr{display:flex;gap:11px;margin-bottom:9px}
.gsi{flex:1}
.gsl{font-size:.66rem;color:var(--ink3);margin-bottom:2px}
.gsv{font-size:.88rem;font-weight:700}
.gtot{text-align:center;border-top:1px solid rgba(0,0,0,.1);padding-top:9px}
.gtl{font-size:.63rem;font-weight:600;letter-spacing:.08em;color:var(--ink3);margin-bottom:3px}
.gtv{font-family:'Fraunces',serif;font-size:1.6rem;font-weight:700}
.gts{font-size:.73rem;margin-top:2px}
/* FINANZAS */
.fts{display:flex;gap:6px;margin-bottom:16px;flex-wrap:wrap}
.ft{background:var(--card);border:1px solid var(--border);border-radius:7px;padding:5px 12px;font-size:.8rem;font-weight:500;color:var(--ink3);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s}
.ft.on{background:var(--accentDim);border-color:var(--accent2);color:var(--accent);font-weight:600}
.fsh{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
.fst{font-size:.85rem;font-weight:700;color:var(--ink)}
.ab{display:inline-flex;align-items:center;gap:5px;background:var(--accentDim);border:1px solid var(--accent2);border-radius:7px;padding:4px 10px;font-size:.74rem;font-weight:600;color:var(--accent);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s}
.ab:hover{background:var(--accent);color:#fff}
.ic{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:12px;margin-bottom:7px}
.r2{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:7px}
.r3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;margin-bottom:7px}
.fl{display:flex;flex-direction:column;gap:3px}
.fl label{font-size:.68rem;font-weight:500;color:var(--ink2)}
.fl input,.fl select{background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:6px 8px;font-size:.83rem;font-family:'DM Sans',sans-serif;color:var(--ink);outline:none}
.fl input:focus{border-color:var(--accent)}
.fp{position:relative}
.fp input{padding-left:18px}
.fp::before{content:'$';position:absolute;left:7px;top:50%;transform:translateY(-50%);color:var(--ink3);font-size:.76rem;pointer-events:none}
.db{background:none;border:none;font-size:.74rem;color:var(--down);cursor:pointer;font-family:'DM Sans',sans-serif;font-weight:500;padding:4px}
.tgl{width:33px;height:17px;border-radius:9px;background:var(--border);cursor:pointer;position:relative;transition:background .2s;border:none;padding:0}
.tgl.on{background:var(--accent)}
.tglth{width:13px;height:13px;border-radius:7px;background:#fff;position:absolute;top:2px;left:2px;transition:transform .2s;box-shadow:0 1px 2px rgba(0,0,0,.2)}
.tgl.on .tglth{transform:translateX(16px)}
.ub{height:3px;background:var(--border);border-radius:100px;overflow:hidden}
.uf{height:100%;border-radius:100px}
/* FIN RESUMEN */
.fkb{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);padding:16px;margin-bottom:9px}
.fkr{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin-bottom:11px}
.fks{background:var(--card);border:1px solid;border-radius:var(--r);padding:10px}
.fkl{font-size:.66rem;color:var(--ink3);margin-bottom:2px}
.fkv{font-size:.92rem;font-weight:700}
/* DONA */
.dwrap{display:flex;gap:22px;align-items:center;flex-wrap:wrap}
.dleg{display:flex;flex-direction:column;gap:7px;flex:1;min-width:160px}
.dli{display:flex;align-items:center;gap:7px;font-size:.78rem}
.dld{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.dll{flex:1;color:var(--ink2)}
.dlp{font-weight:700;color:var(--ink)}
/* PLAN / INVERSIONES */
.stp{display:flex;align-items:center;margin-bottom:14px}
.sd{width:26px;height:26px;border-radius:50%;border:2px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:.76rem;font-weight:700;color:var(--ink3);background:var(--card);cursor:pointer;transition:all .2s;flex-shrink:0}
.sd.on{border-color:var(--accent);background:var(--accent);color:#fff}
.sd.dn{border-color:var(--accent2);background:var(--accent2);color:#fff}
.sl2{flex:1;height:2px;background:var(--border);margin:0 4px;transition:background .3s}
.sl2.dn{background:var(--accent2)}
.bn{background:var(--accent);color:#fff;border:none;border-radius:9px;padding:10px 22px;font-size:.86rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif}
.bn:hover{background:#235c43}
.bp{background:var(--bg2);color:var(--ink2);border:1px solid var(--border);border-radius:9px;padding:10px 18px;font-size:.86rem;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif}
.nbs{display:flex;gap:9px;margin-top:16px}
.oc{background:var(--bg);border:1px solid var(--border);border-radius:var(--r);padding:12px;margin-bottom:8px}
.oni{width:100%;background:transparent;border:none;border-bottom:2px solid var(--border);padding:3px 0;font-size:.92rem;font-weight:600;color:var(--ink);font-family:'DM Sans',sans-serif;outline:none;margin-bottom:9px}
.oni:focus{border-color:var(--accent)}
.rpl{display:inline-flex;align-items:center;gap:5px;border-radius:7px;border:1px solid;padding:4px 8px;margin-top:7px;font-size:.74rem;font-weight:600}
/* INV ACTIVAS */
.invc{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);padding:16px;margin-bottom:9px}
.invh{display:flex;align-items:center;justify-content:space-between;margin-bottom:11px}
.invs{font-family:'Fraunces',serif;font-size:1.05rem;font-weight:700}
.inv3{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;margin-bottom:11px}
.ist{background:var(--bg);border-radius:7px;padding:9px}
.isl{font-size:.63rem;color:var(--ink3);margin-bottom:2px}
.isv{font-size:.88rem;font-weight:700}
.inv-rg{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin-bottom:9px}
.iri{border-radius:7px;padding:9px;text-align:center}
.irl{font-size:.6rem;color:var(--ink3);text-transform:uppercase;letter-spacing:.04em;margin-bottom:2px}
.irv{font-size:.92rem;font-weight:700}
/* MACRO */
.mi{background:var(--bg);border:1px solid var(--border);border-radius:7px;display:flex;align-items:center;padding:0 11px;margin-bottom:3px}
.mi input{flex:1;background:none;border:none;padding:9px 0;font-size:1.05rem;font-weight:700;color:var(--ink);font-family:'DM Sans',sans-serif;outline:none}
.mi .suf{font-size:.8rem;color:var(--ink3)}
.mh{font-size:.68rem;color:var(--ink3);margin-bottom:11px}
.eq{display:flex;gap:7px;flex-wrap:wrap}
.eqb{border-radius:7px;border-width:1.5px;border-style:solid;padding:7px 11px;cursor:pointer;background:transparent;font-family:'DM Sans',sans-serif;text-align:center}
.eqb:hover{opacity:.8}
/* CALC */
.cr{background:var(--accent);border-radius:var(--r2);padding:20px;margin-bottom:13px;color:#fff}
.crl{font-size:.68rem;font-weight:600;letter-spacing:.06em;opacity:.7;margin-bottom:3px}
.cra{font-family:'Fraunces',serif;font-size:2.1rem;font-weight:700;margin-bottom:12px;letter-spacing:-.03em}
.crr{display:grid;grid-template-columns:repeat(3,1fr);gap:7px}
.cri label{font-size:.63rem;opacity:.65;margin-bottom:2px;display:block}
.cri span{font-size:.88rem;font-weight:700}
.ctl{margin-bottom:15px}
.cth{display:flex;justify-content:space-between;margin-bottom:6px}
.ctl-l{font-size:.78rem;font-weight:500;color:var(--ink2)}
.ctl-v{font-size:.8rem;font-weight:700;color:var(--ink)}
.ctl-r{display:flex;align-items:center;gap:8px}
.ctl-b{width:30px;height:30px;border-radius:6px;background:var(--bg2);border:1px solid var(--border);font-size:1rem;color:var(--accent);cursor:pointer;font-family:'DM Sans',sans-serif;display:flex;align-items:center;justify-content:center}
.ctl-b:hover{background:var(--accentDim)}
.ctl-t{flex:1;height:3px;background:var(--border);border-radius:100px;overflow:hidden}
.ctl-f{height:100%;background:var(--accent);border-radius:100px}
.bch{height:90px;display:flex;align-items:flex-end;gap:3px}
.bco{flex:1;display:flex;flex-direction:column;align-items:center;height:100%}
.bin2{width:100%;background:var(--bg2);border-radius:2px 2px 0 0;position:relative;overflow:hidden;display:flex;flex-direction:column;justify-content:flex-start}
.bga{width:100%;background:var(--accent)}
.blb{font-size:.57rem;color:var(--ink3);margin-top:2px}
.dt{width:100%;border-collapse:collapse;font-size:.78rem}
.dt th{text-align:left;padding:6px 8px;font-size:.63rem;font-weight:600;color:var(--ink3);text-transform:uppercase;letter-spacing:.06em;border-bottom:1px solid var(--border)}
.dt td{padding:6px 8px;border-bottom:1px solid var(--bg2)}
.dt tr:nth-child(even) td{background:var(--bg)}
/* HERR */
.insc{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);padding:15px;margin-bottom:8px;cursor:pointer;transition:all .2s}
.insc:hover{border-color:var(--accent2);transform:translateY(-1px);box-shadow:var(--shadow2)}
.insn{font-size:.9rem;font-weight:700;margin-bottom:3px}
.insd{font-size:.74rem;color:var(--ink3);line-height:1.5}
