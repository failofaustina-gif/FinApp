  .color-picker-row{display:flex;gap:6px;flex-wrap:wrap;margin-top:6px}
  .color-dot{width:20px;height:20px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:all .15s}
  .color-dot.sel{border-color:var(--ink);transform:scale(1.2)}

  .moneda-toggle{display:flex;align-items:center;background:var(--bg2);border:1px solid var(--border);border-radius:20px;padding:2px;gap:2px;flex-shrink:0}
  .moneda-btn{padding:4px 10px;border-radius:16px;font-size:.72rem;font-weight:600;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;transition:all .15s;color:var(--ink3);background:transparent}
  .moneda-btn.on{background:var(--accent);color:#fff}

  /* GASTOS VARIABLES COMPACTOS */
  .gv-row{display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:1px solid var(--bg2);cursor:pointer;transition:background .1s;position:relative}
  .gv-row:hover{background:var(--bg)}
  .gv-row:last-child{border-bottom:none}
  .gv-cat-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
  .gv-concepto{flex:1;font-size:.845rem;font-weight:600;color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .gv-fecha{font-size:.72rem;color:var(--ink3);flex-shrink:0}
  .gv-monto{font-size:.875rem;font-weight:700;color:var(--ink);flex-shrink:0;min-width:80px;text-align:right}
  .gv-expand{font-size:.72rem;color:var(--ink3);flex-shrink:0;padding:2px 6px}
  .gv-detail{display:none;padding:10px 14px 14px 32px;background:var(--bg);border-bottom:1px solid var(--bg2)}
  .gv-detail.open{display:block}
  .gv-cat-badge{display:inline-flex;align-items:center;gap:5px;border-radius:20px;padding:3px 10px;font-size:.72rem;font-weight:600;border:1px solid;cursor:pointer;margin-bottom:8px}
  /* FILTRO CATEGORIAS */
  .cat-filter{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px}
  .cat-filter-btn{display:inline-flex;align-items:center;gap:5px;border-radius:20px;padding:4px 12px;font-size:.75rem;font-weight:500;border:1px solid var(--border);background:var(--card);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s}
